<!DOCTYPE html>

<html class="dark" lang="en"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>VANGARD Dashboard</title>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&amp;family=Be+Vietnam+Pro:wght@300;400;500;600;700&amp;family=Noto+Sans+Devanagari:wght@400;700&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "on-error-container": "#ffdad6",
                        "secondary": "#c0c1ff",
                        "secondary-fixed-dim": "#c0c1ff",
                        "tertiary-fixed-dim": "#4ae176",
                        "tertiary-fixed": "#6bff8f",
                        "on-error": "#690005",
                        "on-secondary-container": "#b0b2ff",
                        "surface-container": "#1e1e2c",
                        "surface-container-lowest": "#0d0d1a",
                        "outline-variant": "#554336",
                        "primary-fixed-dim": "#ffb77a",
                        "secondary-fixed": "#e1e0ff",
                        "on-tertiary-fixed-variant": "#005321",
                        "surface-dim": "#12121f",
                        "on-surface": "#e3e0f4",
                        "error": "#ffb4ab",
                        "surface-bright": "#383847",
                        "on-tertiary": "#003915",
                        "inverse-surface": "#e3e0f4",
                        "on-surface-variant": "#dbc2b0",
                        "on-secondary": "#1000a9",
                        "secondary-container": "#3131c0",
                        "on-tertiary-container": "#005020",
                        "on-background": "#e3e0f4",
                        "surface-container-low": "#1a1a28",
                        "surface-container-highest": "#343342",
                        "background": "#12121f",
                        "surface": "#12121f",
                        "on-tertiary-fixed": "#002109",
                        "tertiary-container": "#2ccb63",
                        "on-primary-fixed-variant": "#6d3a00",
                        "inverse-primary": "#8f4e00",
                        "error-container": "#93000a",
                        "on-secondary-fixed": "#07006c",
                        "primary-container": "#ff9933",
                        "on-secondary-fixed-variant": "#2f2ebe",
                        "on-primary-container": "#693800",
                        "primary-fixed": "#ffdcc2",
                        "on-primary-fixed": "#2e1500",
                        "surface-variant": "#343342",
                        "surface-tint": "#ffb77a",
                        "outline": "#a38d7c",
                        "surface-container-high": "#292937",
                        "tertiary": "#52e87c",
                        "inverse-on-surface": "#2f2f3d",
                        "primary": "#ffc08d",
                        "on-primary": "#4c2700"
                    },
                    fontFamily: {
                        "headline": ["Plus Jakarta Sans"],
                        "body": ["Be Vietnam Pro"],
                        "label": ["Be Vietnam Pro"],
                        "devanagari": ["Noto Sans Devanagari"]
                    },
                    borderRadius: {"DEFAULT": "1rem", "lg": "2rem", "xl": "3rem", "full": "9999px"},
                },
            },
        }
    </script>
<style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        .starfield {
            background-image: radial-gradient(circle at 2px 2px, rgba(227, 224, 244, 0.05) 1px, transparent 0);
            background-size: 24px 24px;
        }
        .clay-surface {
            box-shadow: inset 0 1px 1px rgba(255, 255, 255, 0.05);
        }
        .body-silhouette {
            filter: drop-shadow(0 0 10px rgba(255, 153, 51, 0.2));
        }
        .hindi-text {
            font-family: 'Noto Sans Devanagari', sans-serif;
            font-size: 110%;
        }
    </style>
</head>
<body class="bg-background text-on-background font-body starfield min-h-screen pb-32">
<!-- TopAppBar -->
<header class="fixed top-0 w-full z-50 flex justify-between items-center px-6 py-4 bg-[#12121f]/70 backdrop-blur-xl shadow-[0_40px_60px_-15px_rgba(0,0,0,0.3)]">
<div class="flex items-center gap-4">
<span class="text-xl font-black text-[#ff9933] tracking-tighter font-headline">VANGARD</span>
</div>
<div class="flex items-center gap-6">
<div class="hidden md:flex gap-8 items-center text-sm font-bold font-headline">
<a class="text-[#ffc08d] font-bold" href="#">Home</a>
<a class="text-[#e3e0f4]/60 hover:bg-[#1e1e2c] transition-colors px-2 py-1 rounded-lg" href="#">Report</a>
<a class="text-[#e3e0f4]/60 hover:bg-[#1e1e2c] transition-colors px-2 py-1 rounded-lg" href="#">Exercise</a>
</div>
<div class="flex items-center gap-3">
<span class="bg-[#ff9933]/10 text-[#ff9933] px-3 py-1 rounded-full text-xs font-bold border border-[#ff9933]/20">⭐ 1,250 XP</span>
<span class="material-symbols-outlined text-[#ff9933]">hearing</span>
<div class="w-8 h-8 rounded-full bg-surface-container-highest border border-outline-variant/20 overflow-hidden">
<img alt="User profile avatar" data-alt="User avatar placeholder with abstract human icon" src="https://lh3.googleusercontent.com/aida-public/AB6AXuAVHTxZfq2yC7OD3wOitpPglAcXNm3y5zQFvBo4H6aMzwJGLe_E5JJqv681QM5IPE416E14usjqAlRfT4PU4t6m9g0lDvpNDMMdctx7OvG3l1yZWWIBjd7Q7YiMf18OoFUgWU9jCIkTlFdRnTNEWL7PRLgm8Phtp9dwzmapNurPbmQk-15T2c5gPfwXCcv2RJal5PNh_6SIP77li8D2NkvRbaUmrdKZOKW4kMitophx0o_FHyBeVTbdZo6koCtmSxCtet136GNS9Cc"/>
</div>
</div>
</div>
</header>
<main class="pt-24 px-4 md:px-8 max-w-7xl mx-auto">
<!-- Dashboard Header -->
<div class="mb-10 flex flex-col md:flex-row md:items-end justify-between gap-4">
<div>
<h1 class="text-4xl md:text-5xl font-black font-headline text-on-background tracking-tight mb-2">Health Analysis</h1>
<p class="text-on-surface-variant font-medium">Deep insights powered by VANGARD AI Engine</p>
</div>
<div class="flex gap-2">
<div class="bg-surface-container-high px-4 py-2 rounded-xl flex items-center gap-2">
<span class="w-2 h-2 rounded-full bg-tertiary"></span>
<span class="text-xs font-bold uppercase tracking-widest text-on-surface/70">Sync: Live</span>
</div>
</div>
</div>
<!-- Bento Grid Layout -->
<div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8">
<!-- Card 1: Report Summary -->
<div class="bg-surface-container p-8 rounded-xl clay-surface flex flex-col justify-between min-h-[320px]">
<div class="flex justify-between items-start mb-6">
<div class="bg-error-container text-on-error-container px-4 py-1.5 rounded-full text-xs font-black tracking-widest uppercase">URGENT</div>
<span class="material-symbols-outlined text-on-surface-variant">description</span>
</div>
<div>
<h2 class="text-2xl font-bold font-headline mb-4 text-primary">Report Summary / रिपोर्ट सारांश</h2>
<p class="text-on-surface-variant leading-relaxed mb-4">Significant metabolic deviations detected in recent biochemistry profile. Priority focus on lipid panels and glycemic index markers required.</p>
<p class="hindi-text text-on-surface/90 leading-relaxed italic">हालिया बायोकेमिस्ट्री रिपोर्ट में महत्वपूर्ण मेटाबॉलिक बदलाव पाए गए हैं। लिपिड प्रोफाइल और ग्लूकोज स्तर पर ध्यान देना आवश्यक है।</p>
</div>
</div>
<!-- Card 2: Hindi Simple Explanation -->
<div class="bg-surface-container-low border-2 border-primary/30 p-8 rounded-xl clay-surface flex flex-col justify-between">
<div>
<div class="flex items-center gap-3 mb-6">
<span class="material-symbols-outlined text-primary" data-weight="fill">lightbulb</span>
<h2 class="text-xl font-bold font-headline tracking-tight">आसान भाषा में</h2>
</div>
<p class="hindi-text text-xl text-on-surface leading-snug mb-8">
                        आपकी रिपोर्ट बताती है कि खून में शक्कर की मात्रा थोड़ी बढ़ी हुई है। डरने की बात नहीं है, बस खान-पान में थोड़ा सुधार और वॉक की जरूरत है।
                    </p>
</div>
<button class="w-full bg-primary-container text-on-primary-container py-4 rounded-xl font-bold flex items-center justify-center gap-3 hover:scale-[1.02] transition-transform active:scale-95">
<span class="material-symbols-outlined">headset</span>
                    Listen to Summary / सुनें
                </button>
</div>
<!-- Card 3: Body Map -->
<div class="bg-surface-container p-8 rounded-xl clay-surface md:row-span-2 flex flex-col items-center">
<h2 class="text-lg font-bold font-headline self-start mb-8 text-on-surface-variant tracking-widest uppercase">Anatomical Focus</h2>
<div class="relative w-full max-w-[280px] aspect-[1/2] flex items-center justify-center">
<!-- Body Silhouette SVG Placeholder -->
<div class="body-silhouette w-full h-full flex items-center justify-center">
<img alt="Body Silhouette" class="opacity-20 grayscale" data-alt="Stylized human anatomical silhouette in a dark interface" src="https://lh3.googleusercontent.com/aida-public/AB6AXuDYwU7vG8YJw599x9b55ozmsupMFSu2kuUbgD-iJ2hvDZzw9WxTKPR8AEyV927Lh8JDsx2XIxgWUmuqqMRuA8vWt2yXdm8EaeatK12pCPKe6E2SlGDLwJrfp-q5vB1eM8URloEpr1wzRV481XyhtDVqKztFpnh_lAfMvS5K_sHt4I73WIfxNqm8fG5N-Tgg1MjMojLW46Db6KqVYqd9JEF5kdgejIyUcW57eCUG3rYLhB2pTXqNdbYmjTxRgyagr80xoz-Z4ZKsEvc"/>
</div>
<!-- Hotspots -->
<div class="absolute top-[22%] left-[45%] w-6 h-6">
<div class="absolute inset-0 bg-primary rounded-full animate-ping opacity-75"></div>
<div class="relative bg-primary w-6 h-6 rounded-full flex items-center justify-center shadow-[0_0_20px_rgba(255,153,51,0.6)]">
<span class="material-symbols-outlined text-[12px] text-on-primary" data-weight="fill">favorite</span>
</div>
<span class="absolute left-8 top-0 whitespace-nowrap text-xs font-bold text-primary bg-primary/10 px-2 py-1 rounded-md">Heart Activity</span>
</div>
<div class="absolute top-[40%] left-[35%] w-6 h-6">
<div class="absolute inset-0 bg-primary rounded-full animate-ping opacity-40"></div>
<div class="relative bg-primary w-6 h-6 rounded-full flex items-center justify-center shadow-[0_0_20px_rgba(255,153,51,0.6)]">
<span class="material-symbols-outlined text-[12px] text-on-primary" data-weight="fill">vital_signs</span>
</div>
<span class="absolute right-8 top-0 whitespace-nowrap text-xs font-bold text-primary bg-primary/10 px-2 py-1 rounded-md">Liver Focus</span>
</div>
</div>
</div>
<!-- Card 4: Lab Values Table -->
<div class="bg-surface-container p-8 rounded-xl clay-surface">
<h2 class="text-lg font-bold font-headline mb-6 text-on-surface-variant tracking-widest uppercase">Lab Parameters</h2>
<div class="space-y-4">
<div class="flex items-center justify-between p-4 bg-surface-container-low rounded-2xl">
<div>
<p class="font-bold text-on-surface">HbA1c</p>
<p class="text-xs text-on-surface-variant">Blood Sugar Avg</p>
</div>
<div class="flex items-center gap-4">
<span class="font-black text-lg text-on-surface">6.8%</span>
<span class="bg-error-container/20 text-error px-3 py-1 rounded-full text-[10px] font-black uppercase">HIGH</span>
</div>
</div>
<div class="flex items-center justify-between p-4 bg-surface-container-low rounded-2xl">
<div>
<p class="font-bold text-on-surface">LDL Cholesterol</p>
<p class="text-xs text-on-surface-variant">Bad Fat</p>
</div>
<div class="flex items-center gap-4">
<span class="font-black text-lg text-on-surface">112</span>
<span class="bg-tertiary-container/20 text-tertiary px-3 py-1 rounded-full text-[10px] font-black uppercase">NORMAL</span>
</div>
</div>
<div class="flex items-center justify-between p-4 bg-surface-container-low rounded-2xl">
<div>
<p class="font-bold text-on-surface">Vitamin D3</p>
<p class="text-xs text-on-surface-variant">Sunshine Nutrients</p>
</div>
<div class="flex items-center gap-4">
<span class="font-black text-lg text-on-surface">18</span>
<span class="bg-secondary-container/20 text-secondary px-3 py-1 rounded-full text-[10px] font-black uppercase">LOW</span>
</div>
</div>
</div>
</div>
<!-- Card 5: AI Confidence Gauge -->
<div class="bg-surface-container p-8 rounded-xl clay-surface flex flex-col items-center justify-center text-center">
<h2 class="text-lg font-bold font-headline mb-6 text-on-surface-variant tracking-widest uppercase">AI Confidence</h2>
<div class="relative w-48 h-24 mb-4">
<!-- Semicircle Arc SVG -->
<svg class="w-full h-full transform overflow-visible" viewbox="0 0 100 50">
<path class="text-surface-container-highest" d="M 10 50 A 40 40 0 0 1 90 50" fill="none" stroke="currentColor" stroke-width="8"></path>
<path class="text-tertiary" d="M 10 50 A 40 40 0 0 1 85 20" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="8" style="stroke-dasharray: 126; stroke-dashoffset: 20;"></path>
</svg>
<div class="absolute inset-0 flex flex-col items-center justify-end pb-1">
<span class="text-3xl font-black text-on-surface">94%</span>
</div>
</div>
<p class="text-xs text-on-surface-variant font-medium max-w-[200px]">Verified against 14k+ similar clinical profiles</p>
</div>
<!-- Card 6: Next Steps Checklist -->
<div class="bg-surface-container p-8 rounded-xl clay-surface overflow-hidden">
<h2 class="text-lg font-bold font-headline mb-6 text-on-surface-variant tracking-widest uppercase">Next Steps</h2>
<div class="space-y-4 max-h-[220px] overflow-y-auto pr-2 custom-scrollbar">
<div class="flex items-center justify-between group cursor-pointer">
<div class="flex items-center gap-4">
<div class="w-6 h-6 rounded-lg bg-surface-container-highest border border-outline-variant/30 flex items-center justify-center group-hover:border-tertiary transition-colors">
<span class="material-symbols-outlined text-xs text-tertiary opacity-0 group-hover:opacity-100">check</span>
</div>
<span class="text-sm font-medium">Log 20 min morning walk</span>
</div>
<span class="text-[10px] font-bold text-tertiary">+5 XP</span>
</div>
<div class="flex items-center justify-between group cursor-pointer">
<div class="flex items-center gap-4">
<div class="w-6 h-6 rounded-lg bg-surface-container-highest border border-outline-variant/30 flex items-center justify-center">
<span class="material-symbols-outlined text-xs text-tertiary opacity-0">check</span>
</div>
<span class="text-sm font-medium">Update fasting glucose</span>
</div>
<span class="text-[10px] font-bold text-tertiary">+5 XP</span>
</div>
<div class="flex items-center justify-between group cursor-pointer">
<div class="flex items-center gap-4">
<div class="w-6 h-6 rounded-lg bg-tertiary flex items-center justify-center">
<span class="material-symbols-outlined text-xs text-on-tertiary" style="font-variation-settings: 'FILL' 1;">check</span>
</div>
<span class="text-sm font-medium line-through text-on-surface-variant/50">Book doctor consultation</span>
</div>
<span class="text-[10px] font-bold text-on-surface-variant/30">DONE</span>
</div>
</div>
</div>
<!-- Card 7: Share with Family -->
<div class="md:col-span-2 bg-gradient-to-br from-surface-container-high to-surface-container p-8 rounded-xl clay-surface flex flex-col md:flex-row items-center justify-between gap-6 border border-white/5">
<div class="flex items-center gap-6">
<div class="w-16 h-16 rounded-full bg-secondary/10 flex items-center justify-center text-secondary">
<span class="material-symbols-outlined text-3xl">groups</span>
</div>
<div>
<h2 class="text-xl font-bold font-headline mb-1">Share Insights with Family</h2>
<p class="text-on-surface-variant text-sm">Keep your loved ones updated on your health journey effortlessly.</p>
</div>
</div>
<div class="flex gap-3 w-full md:w-auto">
<button class="flex-1 md:flex-none bg-[#25D366]/10 text-[#25D366] px-6 py-3 rounded-xl font-bold border border-[#25D366]/30 flex items-center justify-center gap-2 hover:bg-[#25D366]/20 transition-colors">
<span class="material-symbols-outlined text-sm">share</span>
                        WhatsApp
                    </button>
<button class="flex-1 md:flex-none bg-surface-bright text-on-surface px-6 py-3 rounded-xl font-bold flex items-center justify-center gap-2 hover:bg-surface-container-highest transition-colors">
<span class="material-symbols-outlined text-sm">content_copy</span>
                        Copy Summary
                    </button>
</div>
</div>
</div>
</main>
<!-- BottomNavBar -->
<nav class="fixed bottom-0 left-0 w-full z-50 flex justify-around items-center px-4 pb-6 pt-2 bg-[#1e1e2c]/80 backdrop-blur-2xl shadow-[0_-10px_40px_rgba(0,0,0,0.5)] rounded-t-[3rem]">
<a class="flex flex-col items-center justify-center bg-[#ff9933]/20 text-[#ffc08d] rounded-full p-3 shadow-[inset_0_1px_1px_rgba(255,255,255,0.1)] active:scale-90 duration-300" href="#">
<span class="material-symbols-outlined">home</span>
<span class="font-be-vietnam-pro text-[10px] uppercase tracking-widest mt-1">Home</span>
</a>
<a class="flex flex-col items-center justify-center text-[#e3e0f4]/40 p-3 hover:text-[#ffc08d] transition-all active:scale-90 duration-300" href="#">
<span class="material-symbols-outlined">add_chart</span>
<span class="font-be-vietnam-pro text-[10px] uppercase tracking-widest mt-1">Report</span>
</a>
<a class="flex flex-col items-center justify-center text-[#e3e0f4]/40 p-3 hover:text-[#ffc08d] transition-all active:scale-90 duration-300" href="#">
<span class="material-symbols-outlined">fitness_center</span>
<span class="font-be-vietnam-pro text-[10px] uppercase tracking-widest mt-1">Exercise</span>
</a>
<a class="flex flex-col items-center justify-center text-[#e3e0f4]/40 p-3 hover:text-[#ffc08d] transition-all active:scale-90 duration-300" href="#">
<span class="material-symbols-outlined">restaurant</span>
<span class="font-be-vietnam-pro text-[10px] uppercase tracking-widest mt-1">Nutrition</span>
</a>
<a class="flex flex-col items-center justify-center text-[#e3e0f4]/40 p-3 hover:text-[#ffc08d] transition-all active:scale-90 duration-300" href="#">
<span class="material-symbols-outlined">self_improvement</span>
<span class="font-be-vietnam-pro text-[10px] uppercase tracking-widest mt-1">Wellness</span>
</a>
</nav>
<!-- Confetti Simulation (CSS Only Visuals) -->
<div class="fixed inset-0 pointer-events-none z-[100] overflow-hidden">
<div class="absolute top-[-10%] left-[20%] w-2 h-2 bg-primary rotate-45 animate-bounce" style="animation-duration: 3s;"></div>
<div class="absolute top-[-5%] left-[50%] w-3 h-1 bg-tertiary -rotate-12 animate-bounce" style="animation-duration: 4.5s;"></div>
<div class="absolute top-[-15%] left-[80%] w-2 h-2 bg-secondary rotate-90 animate-bounce" style="animation-duration: 3.5s;"></div>
</div>
</body></html>