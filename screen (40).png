<!DOCTYPE html>

<html class="dark" lang="en"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>VANGARD - Exercise Plan</title>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,400;0,700;0,800;1,800&amp;family=Be+Vietnam+Pro:wght@400;500;700&amp;family=Noto+Sans+Devanagari:wght@400;700&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "surface-dim": "#12121f",
                        "surface-container-low": "#1a1a28",
                        "on-secondary-fixed": "#07006c",
                        "surface-container-highest": "#343342",
                        "surface-bright": "#383847",
                        "surface-container": "#1e1e2c",
                        "on-primary": "#4c2700",
                        "on-primary-fixed": "#2e1500",
                        "on-surface-variant": "#dbc2b0",
                        "surface-container-lowest": "#0d0d1a",
                        "secondary-container": "#3131c0",
                        "tertiary-fixed": "#6bff8f",
                        "on-primary-container": "#693800",
                        "tertiary-fixed-dim": "#4ae176",
                        "on-tertiary-container": "#005020",
                        "inverse-on-surface": "#2f2f3d",
                        "surface-tint": "#ffb77a",
                        "primary-fixed": "#ffdcc2",
                        "on-secondary-fixed-variant": "#2f2ebe",
                        "on-error-container": "#ffdad6",
                        "on-secondary": "#1000a9",
                        "on-primary-fixed-variant": "#6d3a00",
                        "on-background": "#e3e0f4",
                        "error-container": "#93000a",
                        "primary": "#ffc08d",
                        "inverse-surface": "#e3e0f4",
                        "background": "#12121f",
                        "primary-container": "#ff9933",
                        "on-tertiary-fixed": "#002109",
                        "on-error": "#690005",
                        "secondary-fixed": "#e1e0ff",
                        "tertiary-container": "#2ccb63",
                        "surface-container-high": "#292937",
                        "surface-variant": "#343342",
                        "error": "#ffb4ab",
                        "primary-fixed-dim": "#ffb77a",
                        "outline": "#a38d7c",
                        "on-tertiary-fixed-variant": "#005321",
                        "surface": "#12121f",
                        "secondary": "#c0c1ff",
                        "on-tertiary": "#003915",
                        "inverse-primary": "#8f4e00",
                        "tertiary": "#52e87c",
                        "secondary-fixed-dim": "#c0c1ff",
                        "on-surface": "#e3e0f4",
                        "outline-variant": "#554336",
                        "on-secondary-container": "#b0b2ff"
                    },
                    fontFamily: {
                        "headline": ["Plus Jakarta Sans"],
                        "body": ["Be Vietnam Pro"],
                        "label": ["Be Vietnam Pro"]
                    },
                    borderRadius: { "DEFAULT": "1rem", "lg": "2rem", "xl": "3rem", "full": "9999px" },
                },
            },
        }
    </script>
<style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        .starfield-bg {
            background-image: radial-gradient(circle, rgba(227, 224, 244, 0.1) 1px, transparent 1px);
            background-size: 24px 24px;
        }
        .clay-card {
            box-shadow: inset 0 1px 1px rgba(255, 255, 255, 0.05);
        }
        .inner-glow-top {
            box-shadow: inset 0 1px 0 0 rgba(255, 255, 255, 0.1);
        }
        .active-recovery-gradient {
            background: linear-gradient(135deg, #ff9933 0%, #ffc08d 100%);
        }
        .path-line {
            stroke-dasharray: 8 8;
        }
    </style>
</head>
<body class="bg-background text-on-background font-body starfield-bg selection:bg-primary-container selection:text-on-primary-container min-h-screen pb-32">
<!-- TopAppBar -->
<header class="fixed top-0 left-0 w-full flex justify-between items-center px-6 py-4 bg-[#12121f]/70 backdrop-blur-xl z-50 tonal-shift-bg shadow-[0_4px_30px_rgba(0,0,0,0.1)] inner-glow-top">
<div class="flex items-center gap-2">
<span class="text-2xl font-black italic tracking-tighter text-[#ff9933] uppercase font-headline">VANGARD</span>
</div>
<div class="flex items-center gap-4">
<div class="flex items-center gap-2 px-3 py-1.5 rounded-full bg-surface-container-high border border-outline-variant/10">
<span class="material-symbols-outlined text-primary-container text-sm" style="font-variation-settings: 'FILL' 1;">military_tech</span>
<span class="text-primary font-headline font-bold text-sm tracking-tight">XP: 2,450</span>
</div>
<div class="flex items-center gap-2">
<span class="material-symbols-outlined text-on-background/60 hover:scale-105 transition-transform cursor-pointer">military_tech</span>
<span class="material-symbols-outlined text-on-background/60 hover:scale-105 transition-transform cursor-pointer">bolt</span>
</div>
</div>
</header>
<main class="pt-24 px-6 max-w-5xl mx-auto space-y-10">
<!-- Active Recovery Hero Banner -->
<section class="relative overflow-hidden rounded-xl active-recovery-gradient p-8 flex flex-col md:flex-row justify-between items-center gap-6 shadow-[0_20px_50px_rgba(255,153,51,0.2)]">
<div class="space-y-2 z-10">
<span class="bg-on-primary-fixed/20 text-on-primary-fixed px-3 py-1 rounded-full text-xs font-bold uppercase tracking-widest font-label">Current Phase</span>
<h1 class="font-headline display-sm font-extrabold text-on-primary-fixed leading-tight">Active Recovery</h1>
<p class="text-on-primary-fixed/80 max-w-md font-medium">Focus on mobility and low-intensity movement to prepare for the Peak Climb. Your muscles need this oxygen flow.</p>
<div class="flex gap-4 pt-4">
<div class="bg-on-primary-fixed/10 p-3 rounded-lg backdrop-blur-md">
<p class="text-[10px] uppercase font-bold opacity-60">Power Level</p>
<p class="text-xl font-black italic">LVL 42</p>
</div>
<div class="bg-on-primary-fixed/10 p-3 rounded-lg backdrop-blur-md">
<p class="text-[10px] uppercase font-bold opacity-60">XP Multiplier</p>
<p class="text-xl font-black italic">1.5X</p>
</div>
</div>
</div>
<div class="relative w-48 h-48 md:w-64 md:h-64 flex items-center justify-center">
<!-- Concentric Progress Orb -->
<svg class="w-full h-full transform -rotate-90">
<circle class="text-on-primary-fixed/10" cx="50%" cy="50%" fill="transparent" r="40%" stroke="currentColor" stroke-width="12"></circle>
<circle class="text-on-primary-fixed drop-shadow-[0_0_8px_rgba(255,255,255,0.4)]" cx="50%" cy="50%" fill="transparent" r="40%" stroke="currentColor" stroke-dasharray="251.2" stroke-dashoffset="62.8" stroke-linecap="round" stroke-width="12"></circle>
</svg>
<div class="absolute inset-0 flex flex-col items-center justify-center text-on-primary-fixed">
<span class="material-symbols-outlined text-4xl" style="font-variation-settings: 'FILL' 1;">self_improvement</span>
<span class="text-2xl font-black">75%</span>
</div>
</div>
</section>
<!-- Hill Climb Level Select / Map Selector -->
<section class="space-y-6">
<div class="flex justify-between items-end">
<div>
<h2 class="font-headline title-lg font-bold text-primary">Hill Climb: Week 3</h2>
<p class="text-on-surface-variant body-md">Navigate the terrain to reach the summit.</p>
</div>
<div class="bg-surface-container rounded-full px-4 py-2 text-sm font-bold flex items-center gap-2 text-on-surface/80">
<span class="material-symbols-outlined text-tertiary" style="font-variation-settings: 'FILL' 1;">explore</span>
                    MOUNTAIN TRAIL
                </div>
</div>
<div class="relative bg-surface-container-lowest rounded-xl p-10 min-h-[300px] overflow-hidden flex items-center justify-center clay-card border border-white/5">
<div class="absolute inset-0 opacity-20 pointer-events-none" data-location="Mountainous Terrain Map" style="">
<svg fill="none" height="100%" viewbox="0 0 800 300" width="100%" xmlns="http://www.w3.org/2000/svg">
<path d="M50 250C150 250 200 50 350 50C500 50 550 200 750 200" opacity="0.3" stroke="white" stroke-dasharray="10 10" stroke-width="2"></path>
</svg>
</div>
<div class="relative flex justify-between w-full max-w-4xl items-center">
<!-- Day Nodes -->
<div class="flex flex-col items-center gap-2 group">
<div class="w-14 h-14 rounded-full bg-tertiary-container flex items-center justify-center text-on-tertiary-container shadow-[0_0_20px_rgba(44,203,99,0.3)] border-4 border-surface-container-lowest scale-110">
<span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">check</span>
</div>
<span class="font-label text-xs font-bold uppercase tracking-widest text-tertiary">Day 15</span>
</div>
<div class="h-1 w-full bg-gradient-to-r from-tertiary-container to-primary-container mx-2 opacity-30"></div>
<div class="flex flex-col items-center gap-2 group">
<div class="w-14 h-14 rounded-full bg-primary-container flex items-center justify-center text-on-primary-container shadow-[0_0_30px_rgba(255,153,51,0.5)] border-4 border-surface-container-lowest scale-125 ring-4 ring-primary-container/20">
<span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">directions_run</span>
</div>
<span class="font-label text-xs font-bold uppercase tracking-widest text-primary">Day 16</span>
</div>
<div class="h-1 w-full bg-surface-container-high mx-2"></div>
<div class="flex flex-col items-center gap-2 group opacity-40">
<div class="w-14 h-14 rounded-full bg-surface-container-highest flex items-center justify-center text-on-surface-variant border-4 border-surface-container-lowest">
<span class="material-symbols-outlined">lock</span>
</div>
<span class="font-label text-xs font-bold uppercase tracking-widest">Day 17</span>
</div>
<div class="h-1 w-full bg-surface-container-high mx-2"></div>
<div class="flex flex-col items-center gap-2 group opacity-40">
<div class="w-14 h-14 rounded-full bg-surface-container-highest flex items-center justify-center text-on-surface-variant border-4 border-surface-container-lowest">
<span class="material-symbols-outlined">mountain_flag</span>
</div>
<span class="font-label text-xs font-bold uppercase tracking-widest">Day 18</span>
</div>
</div>
</div>
</section>
<!-- Stats Scoreboard (Bento Style) -->
<section class="grid grid-cols-1 md:grid-cols-3 gap-6">
<div class="bg-surface-container p-6 rounded-lg clay-card space-y-4">
<div class="flex justify-between items-start">
<span class="material-symbols-outlined text-primary text-3xl">speed</span>
<span class="text-[10px] font-bold bg-primary/10 text-primary px-2 py-0.5 rounded uppercase">Elite</span>
</div>
<div>
<h3 class="text-on-surface-variant text-sm font-bold uppercase tracking-wider">Avg Heart Rate</h3>
<p class="text-3xl font-headline font-extrabold">142 <span class="text-lg opacity-40">BPM</span></p>
</div>
</div>
<div class="bg-surface-container p-6 rounded-lg clay-card space-y-4">
<div class="flex justify-between items-start">
<span class="material-symbols-outlined text-tertiary text-3xl">mode_fan</span>
<span class="text-[10px] font-bold bg-tertiary/10 text-tertiary px-2 py-0.5 rounded uppercase">Steady</span>
</div>
<div>
<h3 class="text-on-surface-variant text-sm font-bold uppercase tracking-wider">Oxygen Flow</h3>
<p class="text-3xl font-headline font-extrabold">98 <span class="text-lg opacity-40">%</span></p>
</div>
</div>
<div class="bg-surface-container p-6 rounded-lg clay-card space-y-4">
<div class="flex justify-between items-start">
<span class="material-symbols-outlined text-secondary text-3xl">timer</span>
<span class="text-[10px] font-bold bg-secondary/10 text-secondary px-2 py-0.5 rounded uppercase">Personal Best</span>
</div>
<div>
<h3 class="text-on-surface-variant text-sm font-bold uppercase tracking-wider">Active Time</h3>
<p class="text-3xl font-headline font-extrabold">42:15</p>
</div>
</div>
</section>
<!-- Exercise Details -->
<section class="space-y-6">
<h2 class="font-headline title-lg font-bold">Today's Missions</h2>
<div class="space-y-4">
<!-- Mission 1 -->
<div class="bg-surface-container p-6 rounded-xl clay-card flex flex-col md:flex-row gap-6 items-center">
<div class="w-full md:w-32 h-32 bg-surface-container-low rounded-lg flex items-center justify-center relative group overflow-hidden">
<img alt="Plank exercise" class="absolute inset-0 w-full h-full object-cover opacity-50 group-hover:scale-110 transition-transform duration-500" data-alt="Person performing a plank on a mat" src="https://lh3.googleusercontent.com/aida-public/AB6AXuC-w5riERVPQEkEbRLaZStQUmoM8RhvvYzXuSpmfoDlZXj1v30nnscdWnFiwkBQ2qDVmmjQzOz5-chPni3WaXzm8j2SIdbM6EWiUFcHkyNyQXt4WRdvGt0zFXEKJ_-RxnpsMZKbtlS7L_pD0bes3-8sP276Kh8oaPASkPaa4C2cbm9eOmjNQnJxV7EtfYJTt6yUxjFKJW6yMVaejrBE_M8KUR4XqAmdW5_2PmJTjp1HLADp2Z5nk87Gs2nwZKo7trOR-YgZLUbpF0k"/>
<span class="material-symbols-outlined text-4xl text-primary z-10" style="font-variation-settings: 'FILL' 1;">fitness_center</span>
</div>
<div class="flex-grow space-y-2 text-center md:text-left">
<div class="flex items-center justify-center md:justify-start gap-2">
<span class="text-xs font-bold uppercase bg-surface-container-highest px-2 py-1 rounded text-on-surface-variant">Tier 1: Mobility</span>
<span class="text-xs font-bold uppercase text-tertiary flex items-center gap-1">
<span class="material-symbols-outlined text-xs">bolt</span> +150 XP
                            </span>
</div>
<h4 class="font-headline title-md font-bold">Flow Stretching</h4>
<p class="text-on-surface-variant body-md">15 Minutes of dynamic mobility to loosen hip flexors.</p>
</div>
<button class="w-full md:w-auto px-8 py-4 bg-primary-container text-on-primary-fixed font-headline font-extrabold rounded-full shadow-[0_10px_30px_rgba(255,153,51,0.3)] hover:scale-105 active:scale-95 transition-all">
                        FINISH RACE
                    </button>
</div>
<!-- Mission 2 -->
<div class="bg-surface-container p-6 rounded-xl clay-card flex flex-col md:flex-row gap-6 items-center">
<div class="w-full md:w-32 h-32 bg-surface-container-low rounded-lg flex items-center justify-center relative group overflow-hidden">
<img alt="Dumbbells" class="absolute inset-0 w-full h-full object-cover opacity-50 group-hover:scale-110 transition-transform duration-500" data-alt="Weights on a gym floor with dramatic lighting" src="https://lh3.googleusercontent.com/aida-public/AB6AXuDIKFw-Lhax_lXwWDjX0Bl5gFV54swbOm8SuD4bhB5DxmDT9rnYZA8MLtj55A5QnObruFsdLhrbG-tJMmPCOkLmVCQLpbAM-H12qKsdfA_du4kKiQ7k24RTqGabvvkS0FM3TBy0SQA4IBWNeU758iKK7GbwNzReQ7R8hiKzpSxRDLhDo2Csqd-pwbwrKqXaJP84xYxEbwCN5OeORt6BjPM2fK9VnyOagIyclEgdRz5buUoJxX76XKhj2uWFcYwZJEN_Xj8Q25SwteU"/>
<span class="material-symbols-outlined text-4xl text-secondary z-10" style="font-variation-settings: 'FILL' 1;">bolt</span>
</div>
<div class="flex-grow space-y-2 text-center md:text-left">
<div class="flex items-center justify-center md:justify-start gap-2">
<span class="text-xs font-bold uppercase bg-surface-container-highest px-2 py-1 rounded text-on-surface-variant">Tier 2: Power</span>
<span class="text-xs font-bold uppercase text-tertiary flex items-center gap-1">
<span class="material-symbols-outlined text-xs">bolt</span> +350 XP
                            </span>
</div>
<h4 class="font-headline title-md font-bold">Resistance Circuit</h4>
<p class="text-on-surface-variant body-md">3 Rounds: 12 reps bodyweight squats, 15 pushups.</p>
</div>
<button class="w-full md:w-auto px-8 py-4 bg-surface-bright text-on-background/40 font-headline font-extrabold rounded-full border border-white/5 cursor-not-allowed">
                        LOCKED
                    </button>
</div>
</div>
</section>
</main>
<!-- BottomNavBar -->
<nav class="fixed bottom-0 left-0 w-full z-50 flex justify-around items-end px-4 pb-6 h-24 bg-[#1e1e2c]/80 backdrop-blur-2xl rounded-t-[3rem] shadow-[0_-10px_40px_rgba(0,0,0,0.3)]">
<a class="flex flex-col items-center justify-center text-[#e3e0f4]/50 p-2 hover:text-[#ffc08d] transition-all" href="#">
<span class="material-symbols-outlined">sports_esports</span>
<span class="font-label label-sm font-bold uppercase tracking-widest mt-1">Home</span>
</a>
<a class="flex flex-col items-center justify-center text-[#e3e0f4]/50 p-2 hover:text-[#ffc08d] transition-all" href="#">
<span class="material-symbols-outlined">leaderboard</span>
<span class="font-label label-sm font-bold uppercase tracking-widest mt-1">Report</span>
</a>
<a class="flex flex-col items-center justify-center bg-gradient-to-b from-[#ffc08d] to-[#ff9933] text-[#0d0d1a] rounded-full p-3 shadow-[0_0_15px_rgba(255,153,51,0.5)] scale-110 -translate-y-2" href="#">
<span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">fitness_center</span>
<span class="font-label label-sm font-bold uppercase tracking-widest mt-1">Exercise</span>
</a>
<a class="flex flex-col items-center justify-center text-[#e3e0f4]/50 p-2 hover:text-[#ffc08d] transition-all" href="#">
<span class="material-symbols-outlined">restaurant</span>
<span class="font-label label-sm font-bold uppercase tracking-widest mt-1">Nutrition</span>
</a>
<a class="flex flex-col items-center justify-center text-[#e3e0f4]/50 p-2 hover:text-[#ffc08d] transition-all" href="#">
<span class="material-symbols-outlined">self_improvement</span>
<span class="font-label label-sm font-bold uppercase tracking-widest mt-1">Wellness</span>
</a>
</nav>
</body></html>