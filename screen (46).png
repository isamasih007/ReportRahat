<!DOCTYPE html>

<html class="dark" lang="en"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>VANGARD - Race Map</title>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,400;0,700;0,800;1,800&amp;family=Be+Vietnam+Pro:wght@400;500;700;900&amp;family=Noto+Sans+Devanagari:wght@400;700&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "surface-container-high": "#292937",
                        "surface-bright": "#383847",
                        "on-error-container": "#ffdad6",
                        "surface-dim": "#12121f",
                        "surface": "#12121f",
                        "on-secondary-container": "#b0b2ff",
                        "surface-variant": "#343342",
                        "error": "#ffb4ab",
                        "surface-container": "#1e1e2c",
                        "secondary": "#c0c1ff",
                        "inverse-primary": "#8f4e00",
                        "error-container": "#93000a",
                        "surface-tint": "#ffb77a",
                        "surface-container-highest": "#343342",
                        "on-surface-variant": "#dbc2b0",
                        "on-secondary": "#1000a9",
                        "primary-fixed": "#ffdcc2",
                        "tertiary": "#52e87c",
                        "surface-container-lowest": "#0d0d1a",
                        "secondary-fixed-dim": "#c0c1ff",
                        "secondary-fixed": "#e1e0ff",
                        "tertiary-container": "#2ccb63",
                        "on-primary-fixed": "#2e1500",
                        "on-background": "#e3e0f4",
                        "primary-fixed-dim": "#ffb77a",
                        "tertiary-fixed": "#6bff8f",
                        "on-tertiary-fixed-variant": "#005321",
                        "on-tertiary-container": "#005020",
                        "on-tertiary-fixed": "#002109",
                        "tertiary-fixed-dim": "#4ae176",
                        "on-primary-container": "#693800",
                        "inverse-surface": "#e3e0f4",
                        "inverse-on-surface": "#2f2f3d",
                        "primary": "#ffc08d",
                        "outline": "#a38d7c",
                        "on-primary-fixed-variant": "#6d3a00",
                        "on-secondary-fixed-variant": "#2f2ebe",
                        "on-tertiary": "#003915",
                        "on-error": "#690005",
                        "surface-container-low": "#1a1a28",
                        "secondary-container": "#3131c0",
                        "on-secondary-fixed": "#07006c",
                        "on-primary": "#4c2700",
                        "background": "#12121f",
                        "primary-container": "#ff9933",
                        "on-surface": "#e3e0f4",
                        "outline-variant": "#554336"
                    },
                    fontFamily: {
                        "headline": ["Plus Jakarta Sans"],
                        "body": ["Be Vietnam Pro"],
                        "label": ["Be Vietnam Pro"]
                    },
                    borderRadius: {"DEFAULT": "1rem", "lg": "2rem", "xl": "3rem", "full": "9999px"},
                },
            },
        }
    </script>
<style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        .clay-surface {
            box-shadow: inset 0 1px 0 0 rgba(255, 255, 255, 0.05);
        }
        .starfield {
            background-image: radial-gradient(circle at 2px 2px, rgba(255,255,255,0.05) 1px, transparent 0);
            background-size: 24px 24px;
        }
        .racing-font {
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-style: italic;
            text-transform: uppercase;
            letter-spacing: -0.05em;
        }
    </style>
</head>
<body class="bg-surface-dim text-on-surface font-body starfield min-h-screen pb-32">
<!-- TopAppBar -->
<header class="fixed top-0 w-full z-50 flex justify-between items-center px-6 py-4 bg-sky-400/70 dark:bg-slate-900/70 backdrop-blur-xl rounded-b-[3rem] shadow-[inset_0_1px_0_0_rgba(255,255,255,0.1)]">
<div class="text-2xl font-black italic tracking-tighter text-orange-500 dark:text-orange-400">VANGARD</div>
<div class="flex items-center gap-4">
<button class="text-slate-700 dark:text-slate-300 hover:scale-105 transition-transform active:scale-95">
<span class="material-symbols-outlined" data-icon="military_tech">military_tech</span>
</button>
<button class="text-orange-600 dark:text-orange-300 hover:scale-105 transition-transform active:scale-95">
<span class="material-symbols-outlined" data-icon="bolt">bolt</span>
</button>
</div>
</header>
<main class="pt-24 px-6 max-w-lg mx-auto space-y-8">
<!-- Hero Banner: ACTIVE RECOVERY -->
<section class="relative overflow-hidden rounded-xl bg-primary-container p-6 shadow-2xl transform -skew-x-2 border-b-8 border-on-primary-fixed-variant">
<div class="relative z-10">
<h1 class="racing-font text-5xl font-black text-on-primary flex flex-col leading-none">
                    ACTIVE <span class="text-6xl text-white">RECOVERY</span>
</h1>
<div class="mt-4 flex gap-6">
<div class="flex flex-col">
<span class="text-[10px] uppercase font-bold tracking-widest text-on-primary/70">Power Level</span>
<span class="text-2xl font-black text-white italic">LVL 42</span>
</div>
<div class="flex flex-col">
<span class="text-[10px] uppercase font-bold tracking-widest text-on-primary/70">XP Bonus</span>
<span class="text-2xl font-black text-white italic">+15%</span>
</div>
</div>
</div>
<!-- Background Decoration -->
<div class="absolute right-[-20px] top-[-10px] opacity-20">
<span class="material-symbols-outlined text-[120px]" data-icon="speed">speed</span>
</div>
</section>
<!-- Map Selector (Racing Track) -->
<section class="space-y-4">
<div class="flex items-center justify-between px-2">
<h2 class="text-sm font-black uppercase tracking-[0.2em] text-primary">Map Selector</h2>
<span class="text-xs font-bold text-on-surface-variant">STAGE 01/07</span>
</div>
<div class="relative flex overflow-x-auto pb-4 gap-4 no-scrollbar">
<!-- Track Line -->
<div class="absolute top-1/2 left-0 w-full h-1 bg-surface-container-highest -translate-y-1/2 z-0"></div>
<!-- Stations -->
<div class="relative z-10 flex gap-12 px-4">
<button class="flex flex-col items-center gap-2 group">
<div class="w-14 h-14 rounded-full bg-primary-container flex items-center justify-center shadow-[0_0_20px_rgba(255,153,51,0.4)] border-4 border-surface ring-2 ring-primary">
<span class="material-symbols-outlined text-white" data-icon="sports_gymnastics">sports_gymnastics</span>
</div>
<span class="text-[10px] font-black tracking-tighter uppercase text-primary">Day 01</span>
</button>
<button class="flex flex-col items-center gap-2 opacity-50 grayscale">
<div class="w-14 h-14 rounded-full bg-surface-container flex items-center justify-center border-4 border-surface">
<span class="material-symbols-outlined text-on-surface-variant" data-icon="directions_run">directions_run</span>
</div>
<span class="text-[10px] font-black tracking-tighter uppercase">Day 02</span>
</button>
<button class="flex flex-col items-center gap-2 opacity-50 grayscale">
<div class="w-14 h-14 rounded-full bg-surface-container flex items-center justify-center border-4 border-surface">
<span class="material-symbols-outlined text-on-surface-variant" data-icon="fitness_center">fitness_center</span>
</div>
<span class="text-[10px] font-black tracking-tighter uppercase">Day 03</span>
</button>
<button class="flex flex-col items-center gap-2 opacity-30 grayscale">
<div class="w-14 h-14 rounded-full bg-surface-container flex items-center justify-center border-4 border-surface">
<span class="material-symbols-outlined text-on-surface-variant" data-icon="flag">flag</span>
</div>
<span class="text-[10px] font-black tracking-tighter uppercase">Day 04</span>
</button>
</div>
</div>
</section>
<!-- Day Detail Card -->
<section class="bg-surface-container rounded-xl p-6 clay-surface space-y-6">
<div class="flex justify-between items-start">
<div class="space-y-1">
<div class="flex items-center gap-2">
<span class="material-symbols-outlined text-tertiary text-sm" data-icon="self_improvement">self_improvement</span>
<span class="text-[10px] font-black tracking-widest text-tertiary uppercase">Yoga Session</span>
</div>
<h3 class="text-2xl font-black tracking-tight">Sunset Mobility Flow</h3>
</div>
<div class="bg-surface-container-highest p-3 rounded-lg flex items-center justify-center">
<span class="material-symbols-outlined text-primary" data-icon="grid_view" data-weight="fill" style="font-variation-settings: 'FILL' 1;">grid_view</span>
</div>
</div>
<p class="text-sm text-on-surface-variant leading-relaxed">
                A focused recovery session to reset your suspension. 15 minutes of controlled flow to improve range of motion.
            </p>
<div class="bg-surface-container-low p-4 rounded-lg border-l-4 border-primary">
<div class="flex items-start gap-3">
<span class="material-symbols-outlined text-primary text-xl" data-icon="lightbulb">lightbulb</span>
<p class="text-xs font-medium text-on-surface leading-snug">
                        Keep your core engaged during the transitions to maximize efficiency.
                    </p>
</div>
</div>
<button class="w-full py-4 bg-gradient-to-r from-tertiary-container to-tertiary rounded-xl text-on-tertiary-container font-black racing-font text-lg shadow-[0_10px_30px_rgba(44,203,99,0.3)] active:scale-95 transition-all">
                Finish Race · +10 XP
            </button>
</section>
<!-- Engine Performance Bento Grid -->
<section class="space-y-4">
<h2 class="text-sm font-black uppercase tracking-[0.2em] text-on-surface-variant px-2">Engine Performance</h2>
<div class="grid grid-cols-2 gap-4">
<!-- Torque -->
<div class="bg-surface-container-low p-4 rounded-lg space-y-2 border-b-4 border-surface-container-highest">
<div class="flex justify-between items-center">
<span class="material-symbols-outlined text-primary text-lg" data-icon="bolt">bolt</span>
<span class="text-[10px] font-bold text-on-surface-variant">88%</span>
</div>
<div class="text-xs font-black uppercase tracking-tighter">Torque</div>
<div class="h-1.5 w-full bg-surface-container-highest rounded-full overflow-hidden">
<div class="h-full bg-primary w-[88%] rounded-full shadow-[0_0_8px_rgba(255,192,141,0.5)]"></div>
</div>
</div>
<!-- Suspension -->
<div class="bg-surface-container-low p-4 rounded-lg space-y-2 border-b-4 border-surface-container-highest">
<div class="flex justify-between items-center">
<span class="material-symbols-outlined text-secondary text-lg" data-icon="waves">waves</span>
<span class="text-[10px] font-bold text-on-surface-variant">64%</span>
</div>
<div class="text-xs font-black uppercase tracking-tighter">Suspension</div>
<div class="h-1.5 w-full bg-surface-container-highest rounded-full overflow-hidden">
<div class="h-full bg-secondary w-[64%] rounded-full shadow-[0_0_8px_rgba(192,193,255,0.5)]"></div>
</div>
</div>
<!-- Efficiency -->
<div class="bg-surface-container-low p-4 rounded-lg space-y-2 border-b-4 border-surface-container-highest">
<div class="flex justify-between items-center">
<span class="material-symbols-outlined text-tertiary text-lg" data-icon="speed">speed</span>
<span class="text-[10px] font-bold text-on-surface-variant">92%</span>
</div>
<div class="text-xs font-black uppercase tracking-tighter">Efficiency</div>
<div class="h-1.5 w-full bg-surface-container-highest rounded-full overflow-hidden">
<div class="h-full bg-tertiary w-[92%] rounded-full shadow-[0_0_8px_rgba(82,232,124,0.5)]"></div>
</div>
</div>
<!-- Grip -->
<div class="bg-surface-container-low p-4 rounded-lg space-y-2 border-b-4 border-surface-container-highest">
<div class="flex justify-between items-center">
<span class="material-symbols-outlined text-orange-400 text-lg" data-icon="texture">texture</span>
<span class="text-[10px] font-bold text-on-surface-variant">75%</span>
</div>
<div class="text-xs font-black uppercase tracking-tighter">Grip</div>
<div class="h-1.5 w-full bg-surface-container-highest rounded-full overflow-hidden">
<div class="h-full bg-orange-400 w-[75%] rounded-full shadow-[0_0_8px_rgba(251,146,60,0.5)]"></div>
</div>
</div>
<!-- Aerodynamics -->
<div class="bg-surface-container-low p-4 rounded-lg space-y-2 border-b-4 border-surface-container-highest">
<div class="flex justify-between items-center">
<span class="material-symbols-outlined text-blue-400 text-lg" data-icon="air">air</span>
<span class="text-[10px] font-bold text-on-surface-variant">42%</span>
</div>
<div class="text-xs font-black uppercase tracking-tighter">Aero</div>
<div class="h-1.5 w-full bg-surface-container-highest rounded-full overflow-hidden">
<div class="h-full bg-blue-400 w-[42%] rounded-full shadow-[0_0_8px_rgba(96,165,250,0.5)]"></div>
</div>
</div>
<!-- Fueling -->
<div class="bg-surface-container-low p-4 rounded-lg space-y-2 border-b-4 border-surface-container-highest">
<div class="flex justify-between items-center">
<span class="material-symbols-outlined text-red-400 text-lg" data-icon="local_gas_station">local_gas_station</span>
<span class="text-[10px] font-bold text-on-surface-variant">Full</span>
</div>
<div class="text-xs font-black uppercase tracking-tighter">Fueling</div>
<div class="h-1.5 w-full bg-surface-container-highest rounded-full overflow-hidden">
<div class="h-full bg-red-400 w-[100%] rounded-full shadow-[0_0_8px_rgba(248,113,113,0.5)]"></div>
</div>
</div>
</div>
</section>
</main>
<!-- BottomNavBar -->
<nav class="fixed bottom-0 left-0 w-full z-50 flex justify-around items-center px-4 pb-6 pt-2 bg-slate-900/80 dark:bg-black/80 backdrop-blur-2xl rounded-t-[3rem] shadow-[0_-10px_40px_rgba(0,0,0,0.4)]">
<button class="flex flex-col items-center justify-center text-slate-400 p-2 hover:text-orange-300 transition-colors active:scale-90 duration-200">
<span class="material-symbols-outlined" data-icon="settings_input_component">settings_input_component</span>
<span class="font-plus-jakarta text-[10px] uppercase font-black tracking-widest mt-1">Garage</span>
</button>
<button class="flex flex-col items-center justify-center text-slate-400 p-2 hover:text-orange-300 transition-colors active:scale-90 duration-200">
<span class="material-symbols-outlined" data-icon="leaderboard">leaderboard</span>
<span class="font-plus-jakarta text-[10px] uppercase font-black tracking-widest mt-1">Stats</span>
</button>
<button class="flex flex-col items-center justify-center bg-gradient-to-b from-orange-400 to-orange-600 text-white rounded-full p-3 shadow-[0_0_15px_rgba(255,152,0,0.5)] active:scale-90 duration-200">
<span class="material-symbols-outlined" data-icon="sports_score">sports_score</span>
<span class="font-plus-jakarta text-[10px] uppercase font-black tracking-widest mt-1">Race</span>
</button>
<button class="flex flex-col items-center justify-center text-slate-400 p-2 hover:text-orange-300 transition-colors active:scale-90 duration-200">
<span class="material-symbols-outlined" data-icon="local_gas_station">local_gas_station</span>
<span class="font-plus-jakarta text-[10px] uppercase font-black tracking-widest mt-1">Fuel</span>
</button>
<button class="flex flex-col items-center justify-center text-slate-400 p-2 hover:text-orange-300 transition-colors active:scale-90 duration-200">
<span class="material-symbols-outlined" data-icon="person">person</span>
<span class="font-plus-jakarta text-[10px] uppercase font-black tracking-widest mt-1">Driver</span>
</button>
</nav>
</body></html>